{
    "name": "tcs/identity-master",
    "description": "TCS Identity Master — single source of truth for staff/faculty identity (PHP + MySQL).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "onelogin/php-saml": "^4.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-pdo_odbc": "Required for the PowerSchool import — reads PowerSchool's Oracle DB directly over ODBC (needs an Oracle ODBC driver on the host)."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php bin/migrate.php",
        "seed": "php bin/seed.php",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
