# =============================================================================
# TCS Identity Master — environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All secrets/paths come from here — nothing is hardcoded in the app.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=production            # production | staging | development
APP_DEBUG=false              # true only in development; never in production
APP_BASE_URL=https://identity.tuscaloosacityschools.com
# PHP's default timezone. Set it to the SAME zone the database writes timestamps
# in (MariaDB CURRENT_TIMESTAMP / NOW() use the DB server's local zone) so that
# "last run X ago" labels are correct. Mismatch = labels off by the UTC offset.
APP_TIMEZONE=America/Chicago

# --- Database (host shared; one ROLE per connection — least privilege) --------
# Where MySQL runs. CONFIRM host/port with ops before go-live.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tcs_identity
DB_CHARSET=utf8mb4

# 1) Application account — the dashboard/web app. DML on app tables, SELECT on
#    reference + staging. NO GRANT/DDL. Used by public/ pages and services.
DB_APP_USER=idm_app
DB_APP_PASS=change-me-app

# 2) Migrator/owner — schema owner used ONLY by bin/migrate.php (DDL). Keep its
#    credentials out of the web tier; run migrations from a trusted shell.
DB_MIGRATE_USER=idm_migrate
DB_MIGRATE_PASS=change-me-migrate

# 3) Write-back importer — limited writer for OneSync write-back jobs only.
#    INSERT/UPDATE on onesync_writeback, account_sync_status; INSERT/DELETE on
#    account_sync_event (append + prune); SELECT/UPDATE on person (apply
#    usernames + encrypted initial passwords); INSERT on audit_log +
#    lifecycle_event (auditing). Used by bin/import_writeback.php,
#    bin/import_onesync_db.php, and the OneSync write-back API.
DB_WRITEBACK_USER=idm_writeback
DB_WRITEBACK_PASS=change-me-writeback

# 4) OneSync reader — READ-ONLY on v_onesync_source ONLY. This account is handed
#    to OneSync's ODBC source. It must not see base tables. (Documented GRANT in
#    README.) Listed here for completeness/ops; the app never connects as this.
DB_ONESYNC_USER=onesync_ro
DB_ONESYNC_PASS=change-me-onesync

# --- Ingestion / feed file drops (importers read paths from config) ----------
# CONFIRM real delivery paths + schedule with ops (NextGen / PowerSchool).
FEED_NEXTGEN_DIR=/var/idm/feeds/nextgen
FEED_POWERSCHOOL_DIR=/var/idm/feeds/powerschool
# Additional import-source categories (interns, long-term subs, contractors).
FEED_INTERN_DIR=/var/idm/feeds/intern
FEED_SUB_DIR=/var/idm/feeds/sub
FEED_CONTRACTOR_DIR=/var/idm/feeds/contractor

# OneSync write-back: the usernames file OneSync emits (also feeds PS 2 AM autocomm).
ONESYNC_WRITEBACK_FILE=/var/idm/onesync/usernames.csv

# --- PowerSchool source database (read staff records directly via ODBC) ---------
# PowerSchool runs on Oracle. We read active staff straight from it over ODBC
# (TEACHERS WHERE status = 1, plus USERS + extension tables for middle name /
# classification / hire-exit) — this REPLACES the old SFTP CSV feed for
# PowerSchool. Requires the pdo_odbc PHP extension plus an Oracle ODBC driver on
# the host. Grant the user SELECT only. Used by bin/import_powerschool.php and the
# nightly feed pull.
# PS_ODBC_DSN is either a registered ODBC DSN name or a full driver connection
# string, e.g.  Driver={Oracle 21 ODBC driver};DBQ=psprod.host:1521/PSPROD
PS_ODBC_DSN=
PS_ODBC_USER=
PS_ODBC_PASS=
# Optional schema/owner the PS tables live under (table prefix), if not the
# connecting user's default schema. Leave blank for the standard PowerSchool
# read-only accounts (PSNavigator / DataMiner) — they see the tables via synonyms.
PS_ODBC_SCHEMA=
# Students are pulled over the SAME PS_ODBC_* connection (no extra config): a
# straight passthrough of active/future enrollments (STUDENTS WHERE Enroll_Status
# IN (0,3)) into the `student` table that OneSync reads from v_onesync_student_source.
# Run by bin/import_students.php (see deploy/idm-students.* for the nightly timer).

# --- OneSync source database (read its provisioning results directly) ----------
# A SEPARATE MariaDB (OneSync's own DB). Grant the user SELECT only. Used by
# bin/onesync_db_inspect.php (schema discovery) and bin/import_onesync_db.php —
# the nightly pull that is THE provisioning-status path (OneSync does not push
# its export log; it only writes back usernames + initial passwords).
ONESYNC_DB_HOST=
ONESYNC_DB_PORT=3306
ONESYNC_DB_NAME=
ONESYNC_DB_USER=
ONESYNC_DB_PASS=
ONESYNC_DB_CHARSET=utf8mb4
# OneSync's source ids for OUR IDM feeds (os_users.sourceId). There are now two
# separate feeds, each with its own source id; the result importer reads users
# from BOTH (their os_users.userId = our person_uuid). Set the ids OneSync assigns
# to each feed. ONESYNC_DB_SOURCE_ID below is the legacy single-source fallback,
# still honored when the per-feed vars are unset.
ONESYNC_DB_SOURCE_ID_STUDENTS=
ONESYNC_DB_SOURCE_ID_FACULTY=
ONESYNC_DB_SOURCE_ID=
# Cutover switch. ON by default = pull provisioning results from OneSync. Turn it
# OFF once IDM is authoritative for AD/Google (the direct Adaxes + Google syncs):
# bin/import_onesync_db.php then skips, and the admin Services page shows the
# OneSync DB sync as disabled. Prefer the toggle on the Services page (stored in
# app_setting) — leave this COMMENTED so the app can flip it. Setting it here
# pins the value and disables the web toggle.
#ONESYNC_DB_SYNC_ENABLED=true

# OneSync write-back API — usernames + initial passwords ONLY (provisioning
# results are pulled from OneSync's DB by bin/import_onesync_db.php instead).
# OneSync POSTs to /api/onesync/username and /api/onesync/password.
# Shared secret OneSync sends as `Authorization: Bearer <key>` or `X-API-Key`.
# Leave blank to DISABLE the API (the endpoints return 503). Use a long random
# value, e.g. `openssl rand -hex 32`.
ONESYNC_API_KEY=
# Debug log for the write-back API — set true to record every API call (headers,
# masked token, body, response) so you can see why OneSync's calls fail. Turn off
# once working. Path is ONESYNC_API_LOG (default /var/idm/onesync/api_debug.log).
ONESYNC_API_DEBUG=false
ONESYNC_API_LOG=/var/idm/onesync/api_debug.log
# Initial-password write-back: OneSync POSTs the temporary password it set for a
# newly created account to /api/onesync/password. The value is encrypted with
# libsodium under THIS key before it ever touches the database (the DB only
# stores ciphertext). 64 hex chars — generate with `openssl rand -hex 32`.
# Leave blank to DISABLE the password endpoint (returns 503); the rest of the
# API keeps working. Rotating the key makes previously stored passwords
# unreadable — OneSync will re-send on the next provisioning run.
CREDENTIAL_ENC_KEY=

# --- MCP server for Claude (POST /mcp) ----------------------------------------
# Exposes read/edit/admin tools to Claude over the Model Context Protocol. Unlike
# the OneSync API above, auth is PER-USER: each user mints a personal API key
# (Settings > API keys, or bin/api_key.php) and sends it as
# `Authorization: Bearer <key>`. The key acts as that user — the tools Claude can
# list and call are bounded by the user's app role (readonly/editor/admin),
# resolved live on every request. Set false to disable the endpoint (returns 503).
MCP_ENABLED=true

# --- SFTP feed pull (bin/fetch_feeds.php + the "Pull from SFTP" button) -------
# Pull CSVs from the district SFTP server into the FEED_*_DIR dirs, then import.
SFTP_HOST=
SFTP_PORT=234
SFTP_USER=
# Auth: prefer a private key; password is the fallback.
SFTP_PRIVATE_KEY_FILE=/var/idm/sftp/id_ed25519
SFTP_PASSPHRASE=
SFTP_PASS=
# Host-key fingerprint to verify (recommended). Get it with:
#   ssh-keyscan -t ed25519 your.sftp.host | ssh-keygen -lf -    (the SHA256:... value)
SFTP_FINGERPRINT=
# Per-source remote directory (enables that source) + optional glob (default *.csv).
# Downloaded files land in the matching FEED_<SOURCE>_DIR above.
SFTP_NEXTGEN_DIR=
SFTP_NEXTGEN_PATTERN=*.csv
# PowerSchool now reads directly from Oracle (PS_ODBC_* above). Leave these blank
# unless you still drop PowerSchool CSVs on SFTP (legacy fallback).
SFTP_POWERSCHOOL_DIR=
SFTP_POWERSCHOOL_PATTERN=*.csv
SFTP_INTERN_DIR=
SFTP_SUB_DIR=
SFTP_CONTRACTOR_DIR=

# --- PowerSchool staff export (bin/export_powerschool.php) -------------------
# Exports staff changes (new + renamed users) as a tab-delimited AutoComm file
# for the PS Teachers view (docs/powerschool-staff-export.md), then uploads it
# to SFTP_PS_EXPORT_DIR on the same SFTP server above. Local copies (plus a
# 3-row sample and the exceptions log) are kept in EXPORT_POWERSCHOOL_DIR.
EXPORT_POWERSCHOOL_DIR=/var/idm/exports/powerschool
SFTP_PS_EXPORT_DIR=

# --- Matching --------------------------------------------------------------
# name+DOB score at/above this AUTO-matches; below goes to the review queue.
# name-only NEVER auto-matches regardless of threshold.
MATCH_AUTO_THRESHOLD=90

# Comma-separated names (first OR last) whose import rows are skipped as
# non-person/system accounts — e.g. PowerSchool Admin and Lookup users.
IMPORT_EXCLUDE_NAMES=admin,lookup

# Staff drop-out safety valve. After a NextGen import, people whose crosswalk id
# was active but absent from the feed are flagged not-in-NextGen (is_active=0),
# so the dashboard can surface them for disabling. If the share that would drop
# exceeds this ratio (and the active population is sizeable), the step is BLOCKED
# and logged instead — guards against a truncated feed mass-deactivating staff.
NEXTGEN_DROPOUT_MAX_RATIO=0.2

# Student drop-out safety valve. The students passthrough disables (is_active=0)
# any student active before a PowerSchool pull but absent from it. A truncated or
# empty ODBC pull (PS maintenance, a year-rollover status flip, a wrong
# PS_ODBC_SCHEMA) would otherwise deactivate the whole district's students. If the
# share that would drop exceeds this ratio (and the active population is sizeable),
# the drop-out step is BLOCKED and logged instead — inserts/updates still apply.
STUDENT_DROPOUT_MAX_RATIO=0.2

# How many days a person can be gone from the NextGen feed before the dashboard
# flags them for disabling REGARDLESS of exit date (catches leavers NextGen drops
# without ever setting an end date). They must also be off NextGen and still
# enabled. Feeds run nightly, so a week's absence is a clear signal.
NEXTGEN_DROPOUT_FLAG_DAYS=7

# Cap on account_sync_event rows; the status importer prunes oldest beyond this.
ACCOUNT_SYNC_EVENT_CAP=100000

# Staleness thresholds (hours). Feeds + OneSync run nightly, so >26h flags a
# missed run / stale data on the dashboard and person records.
FEED_STALE_HOURS=26
SYNC_STALE_HOURS=26

# Max size (bytes) for a feed CSV uploaded via the web UI (default 20 MB). Must
# also fit within PHP's upload_max_filesize / post_max_size.
UPLOAD_MAX_BYTES=20971520

# --- Admin "Services" page ---------------------------------------------------
# The admin /admin page shows the health of each service (databases, OneSync,
# SFTP, PowerSchool ODBC, VPN), when each background job last ran, and lets
# admins run them on demand. Job runs are recorded in the `service_run` table —
# the app DB user needs INSERT/UPDATE/SELECT on it (covered by "DML on app
# tables" above). Seconds to wait when probing the OneSync source DB for the
# status card, so an unreachable DB fails fast instead of hanging the page.
SERVICE_PING_TIMEOUT=3

# --- VPN status page ---------------------------------------------------------
# Base URL of the read-only pseast-vpn-monitor service (see pseast-vpn-monitor/).
# The /vpn page fetches its /api/status + /api/history server-side and displays
# them. Leave blank to disable the page (it shows a "not configured" notice).
# The monitor usually binds to localhost on this host.
VPN_MONITOR_URL=
# Seconds to wait for the monitor before giving up (the page degrades gracefully).
VPN_MONITOR_TIMEOUT=4

# Restart the VPN service from the /vpn page (editors/admins only). OFF by default:
# the rest of the VPN feature is read-only. When true, a "Restart VPN service"
# button appears for edit/admin roles; it runs `sudo systemctl restart <unit>` on
# THIS host, so the web user (www-data) also needs a NOPASSWD sudoers rule for
# exactly that command — install deploy/idm-vpn-restart.sudoers. Every restart is
# CSRF-protected and written to audit_log.
VPN_CONTROL_ENABLED=false
# The systemd unit to restart (must match the monitor's unit_name in
# pseast-vpn-monitor/config.json). Letters, digits, and @ . _ - only.
VPN_SERVICE_UNIT=openconnect-pseast.service
# Seconds to wait for systemctl before giving up on a restart.
VPN_CONTROL_TIMEOUT=30
# Override the sudo / systemctl paths only if they aren't on the web user's PATH.
#VPN_SUDO_BIN=/usr/bin/sudo
#VPN_SYSTEMCTL_BIN=/usr/bin/systemctl

# --- Admin "Security" dashboard ----------------------------------------------
# The admin /security page shows the runtime state of the host controls set by
# scripts/harden-debian12.sh: firewall (ufw), fail2ban jails + banned IPs, the
# effective sshd policy, automatic updates, AppArmor, and auditd. OFF by default;
# the app-level HTTP-hardening card still shows. Every signal is read-only — this
# page never changes the host.
SECURITY_STATUS_ENABLED=false
#
# Reading firewall/fail2ban/sshd needs root, and there are two ways to get it:
#
# 1) COLLECTOR (recommended, and required on a hardened host). harden-debian12.sh
#    disables proc_open in php-fpm, so the web app CANNOT run commands itself. A
#    root systemd timer (deploy/idm-security-snapshot.{service,timer}) runs
#    bin/security_snapshot.php, which writes this JSON file; the app just reads
#    it — no sudo, no proc_open in the web tier. Set the path to enable this mode.
#SECURITY_STATUS_FILE=/var/idm/security-status.json
# Snapshot older than this (seconds) is shown as stale. Keep the timer interval
# (OnUnitActiveSec, default 120s) well below this.
SECURITY_SNAPSHOT_MAX_AGE=600
#
# 2) LIVE (only where php-fpm may spawn processes — i.e. NOT hardened). Leave
#    SECURITY_STATUS_FILE unset; the app runs a fixed allow-list of read-only
#    commands via `sudo -n`, which needs the NOPASSWD rule in
#    deploy/idm-security-status.sudoers. Seconds to wait per command:
SECURITY_STATUS_TIMEOUT=6
# Absolute tool paths — used by BOTH modes (the collector runs these as root, the
# live mode via sudo). Defaults are Debian 12's.
#SECURITY_SUDO_BIN=sudo
#SECURITY_UFW_BIN=/usr/sbin/ufw
#SECURITY_FAIL2BAN_BIN=/usr/bin/fail2ban-client
#SECURITY_SSHD_BIN=/usr/sbin/sshd
#SECURITY_SYSTEMCTL_BIN=/usr/bin/systemctl

# --- Active Directory verification (Adaxes REST API) -------------------------
# Optional. When set, the person detail page verifies each account against LIVE
# Active Directory via the Adaxes REST API (read-only): account enabled/disabled,
# sAMAccountName, UPN, mail, displayName, OU/DN — compared field-by-field to the
# golden record. Leave ADAXES_BASE_URL blank to disable (the panel shows a
# "not configured" notice). The app NEVER writes to AD — it only reads.
#
# Base URL of the Adaxes REST API (no trailing slash). The host typically
# serves under /restApi (e.g. https://adaxes.example.org/restApi).
ADAXES_BASE_URL=          # e.g. https://adaxes.example.org/restApi
#
# AUTH — the Adaxes REST API does NOT accept HTTP Basic; it uses a security token
# sent in the Adm-Authorization header. Two ways to provide one:
#  1) Static token (recommended, fastest): generate with the New-AdmAccountToken
#     PowerShell cmdlet for a read-only service account and paste it here. No
#     password stored, no per-request handshake.
ADAXES_TOKEN=
#  2) Username + password: the app runs the legacy handshake itself (create an
#     auth session, then exchange it for a token) on each verification. Use a
#     read-only service account; grant it only "Read" on the user OUs you verify.
ADAXES_USERNAME=          # e.g. TCS\\svc-idm-read  (or svc-idm-read@example.org)
ADAXES_PASSWORD=
# Seconds to wait for Adaxes before giving up (the panel degrades gracefully).
ADAXES_TIMEOUT=5
# Adaxes intermittently times out / drops the connection (a transport-level
# "HTTP 0") or returns a gateway error (502/503/504); those are transient, so
# requests (including the auth handshake) are retried. Total tries and the base
# backoff (grows linearly per try: 400ms, 800ms, …). Set attempts to 1 to disable.
#ADAXES_RETRY_ATTEMPTS=3
#ADAXES_RETRY_DELAY_MS=400
# TLS: keep verification ON. For an internal/private CA, point ADAXES_CA_FILE at
# the CA bundle (preferred). Only set ADAXES_VERIFY_TLS=false for a self-signed
# host you cannot otherwise trust — discouraged.
ADAXES_VERIFY_TLS=true
ADAXES_CA_FILE=
# Troubleshooting: log every Adaxes request URL + response snippet so you can
# see exactly what was sent and what AD returned (e.g. a 404 reveals a wrong
# base URL / path). The log holds directory data (PII) and the search filter —
# enable only while debugging, then turn it back off. Never logs credentials.
ADAXES_DEBUG=false
ADAXES_LOG=/var/idm/adaxes_debug.log
# When no AD objectGUID is on file, the person is found by searching AD for any
# of sAMAccountName=username, mail=email, or employeeID=employee_id. If your
# directory stores the employee id under a different attribute (e.g.
# employeeNumber), set it here.
#ADAXES_EMPLOYEE_ID_ATTR=employeeID
# Advanced (rarely needed): override the request paths if your Adaxes version
# differs, and the AD attributes to fetch. All REST endpoints live under
# {base}/api (so the base URL is the …/restApi root, NOT …/restApi/api). The
# object lookup is GET {base}/api/directoryObjects?directoryObject=<DN|GUID>&properties=…
# (the object id is a query parameter, ADAXES_OBJECT_PARAM, not a path segment).
# Defaults shown.
# The fallback search (used when no objectGUID is on file) is a POST to
# {base}/api/directoryObjects/search with a JSON criteria body matching any of
# sAMAccountName / mail / employeeID.
#ADAXES_OBJECTS_PATH=api/directoryObjects
#ADAXES_OBJECT_PARAM=directoryObject
#ADAXES_SEARCH_PATH=api/directoryObjects/search
#ADAXES_PROPERTIES=sAMAccountName,userPrincipalName,mail,displayName,distinguishedName,accountDisabled,userAccountControl,department,title,whenChanged
# Legacy auth handshake endpoints (used only when ADAXES_TOKEN is blank). Defaults
# match Adaxes 2025.1: POST {base}/api/authSessions/create then POST {base}/api/auth.
#ADAXES_SESSION_PATH=api/authSessions/create
#ADAXES_TOKEN_PATH=api/auth

# --- Adaxes WRITE (direct AD provisioning; bypasses OneSync for AD) -----------
# Optional. When enabled, IDM becomes the authoritative WRITER of Active
# Directory accounts — it creates / edits / disables accounts itself through the
# Adaxes REST API instead of publishing v_onesync_source for OneSync to apply.
# See docs/adaxes-provisioning-design.md. OFF by default: with the master switch
# false, the reconciler (bin/adaxes_sync.php) is read-only / dry-run only and
# NEVER writes. Google Workspace provisioning stays on OneSync (separate branch).
#
# Master switch. false = today's read-only behavior; true = writes are allowed
# (still gated by a dry-run flag on the reconciler during rollout).
ADAXES_WRITE_ENABLED=false
# Token for the dedicated WRITE service account. Least privilege: a separate
# Adaxes Security Role granting Create User / Modify / Enable-Disable scoped to
# the staff OUs (generate with New-AdmAccountToken). If unset, the writer falls
# back to ADAXES_TOKEN, then the ADAXES_USERNAME/ADAXES_PASSWORD handshake.
ADAXES_WRITE_TOKEN=
# Endpoints are version-specific — CONFIRM against your deployed Adaxes build
# (docs: https://www.adaxes.com/sdk/ApiDocumentation.RESTApi/). Defaults reuse
# the object collection (create = POST, modify = PATCH). Disable/enable default
# to toggling the accountDisabled property via the modify endpoint; set a
# dedicated operation path only if your build exposes one.
#ADAXES_CREATE_PATH=api/directoryObjects
#ADAXES_MODIFY_PATH=api/directoryObjects
#ADAXES_DISABLE_PATH=
#ADAXES_ENABLE_PATH=
#ADAXES_CREATE_OBJECT_TYPE=user
# Initial password on create. Adaxes Business Rules do NOT fire on REST API
# events, so IDM sets the initial password + "must change at next logon" itself
# right after a create (via the resetPassword endpoint) and records the value
# encrypted on the golden record (requires CREDENTIAL_ENC_KEY). On by default;
# set false only if a create Business Rule is (re-)authored to own the password.
#ADAXES_SET_PASSWORD_ON_CREATE=true
#ADAXES_RESET_PASSWORD_PATH=api/directoryObjects/resetPassword
# Move endpoint — the edit phase relocates an account to the OU it SHOULD live in
# when its container has drifted (e.g. a bus aide created under a building that
# now belongs in OU=trans). Default POSTs the object + destination in the body.
# Two request shapes are supported without a code change: if ADAXES_MOVE_PATH
# contains the literal {id}, the object identity is URL-encoded into the path and
# only the destination rides the body; otherwise both ride the body under the
# field names below (confirm against your build).
#ADAXES_MOVE_PATH=api/directoryObjects/move
#ADAXES_MOVE_OBJECT_FIELD=directoryObject
#ADAXES_MOVE_DESTINATION_FIELD=targetContainer
# Safety valves. The disable ratio mirrors NEXTGEN_DROPOUT_MAX_RATIO: block a
# mass-disable when more than this share of linked AD accounts would be disabled
# in one run (guard applies once at least *_DISABLE_GUARD_MIN are linked). The
# create cap is an absolute ceiling on net-new account creation per run.
ADAXES_WRITE_MAX_DISABLES_RATIO=0.2
#ADAXES_WRITE_DISABLE_GUARD_MIN=20
ADAXES_WRITE_MAX_CREATES=50

# "Run AD sync now" button on the Services page. Because a full sync does a live
# AD lookup per person (minutes, not seconds) it can't run in the web request; the
# button asks systemd to start the oneshot unit in the background:
#   sudo -n systemctl start --no-block idm-adaxes-sync.service
# Off by default; the host must also grant the web user the sudoers rule in
# deploy/idm-adaxes-run.sudoers. The Services page shows the last run either way.
ADAXES_RUN_ENABLED=false
#ADAXES_SERVICE_UNIT=idm-adaxes-sync.service
#ADAXES_SUDO_BIN=sudo
#ADAXES_SYSTEMCTL_BIN=systemctl
#ADAXES_RUN_TIMEOUT=15

# --- Identity minting (IDM becomes the username authority in Phase 3) --------
# When IDM creates accounts it mints the username itself: first initial + last
# name, lowercase (John Smith -> jsmith), with an integer suffix on collision
# (James Smith -> jsmith1). Email and UPN are derived from the final username
# with a fixed domain. Domain is config so a future change is one edit;
# AD_UPN_SUFFIX defaults to AD_EMAIL_DOMAIN.
AD_EMAIL_DOMAIN=tusc.k12.al.us
#AD_UPN_SUFFIX=tusc.k12.al.us
# Container placement for CREATE. The full DN is assembled most-specific first:
#   [OU=<type leaf>,] {school.ad_ou} , {AD_PARENT_OU} , {AD_BASE_DN}
# school.ad_ou holds the RELATIVE building OU (e.g. "OU=CO", or "OU=STC,OU=CO").
# Every provisioned account nests under a shared parent OU (AD_PARENT_OU) and its
# building OU. Contractors/subs/interns get an extra innermost type leaf OU;
# faculty and staff have none. So a contractor at Central Office lands in
# "OU=PTC,OU=CO,OU=Faculty,<AD_BASE_DN>"; a faculty/staff member there lands in
# "OU=CO,OU=Faculty,<AD_BASE_DN>". AD_BASE_DN is REQUIRED for create (people are
# routed to review until it is set).
AD_BASE_DN=DC=tcs,DC=tusc,DC=k12,DC=al,DC=us
#AD_PARENT_OU=OU=Faculty     # shared parent OU every provisioned account nests under
# The OU Adaxes' own scheduled task moves EXPIRED users into after its holding
# period. When set, the disable phase ARCHIVES a leaver whose account is both
# expired and in (or under) this OU — person.ad_archived_at is stamped and the
# person is excluded from future disable-phase scans (no more nightly live
# lookups for fully-processed leavers). A re-hire clears the stamp
# automatically. Full DN or a fragment like "OU=Disabled". Empty = archiving off.
#AD_DISABLED_OU=OU=Disabled Users
# Per-type innermost leaf OU. Defaults: contractor=OU=PTC, sub=OU=Subs (plural —
# matches OneSync's existing placement), intern=OU=Interns; faculty/staff/other
# have none. Override any with AD_OU_<TYPE>.
#AD_OU_CONTRACTOR=OU=PTC
#AD_OU_SUB=OU=Subs
#AD_OU_INTERN=OU=Interns
# Title-driven placement rules that trump the type leaf (mirroring OneSync's
# custom mappings):
#  - Transportation staff live in a transportation OU with NO building segment
#    (OU=trans,OU=Faculty,<base>) and their AD department is overridden. Someone
#    counts as transportation when their title contains "bus" as a whole word
#    (Bus Driver, Bus Aide, Bus Monitor, …) or the word "Transportation"
#    (Transportation Coordinator, Director of Transportation, …), OR their primary
#    building's NextGen code is in AD_TRANSPORTATION_SCHOOL_CODES (default 8410 —
#    the transportation depot), so everyone housed there lands in the trans OU
#    regardless of title. Add any other transportation titles (mechanic,
#    dispatcher, …) to AD_TRANSPORTATION_TITLES (comma-separated).
#  - SROs get an SRO leaf above their building (OU=SRO,OU=<school>,OU=Faculty,<base>).
#AD_OU_TRANSPORTATION=OU=trans          # (legacy alias: AD_OU_BUS_DRIVER)
#AD_DEPT_TRANSPORTATION=Transportation  # (legacy alias: AD_DEPT_BUS_DRIVER)
#AD_TRANSPORTATION_TITLES=
#AD_TRANSPORTATION_SCHOOL_CODES=8410    # NextGen location code(s), comma-separated
#   ^ Each code must map to its OWN dedicated school row (ad_ou=OU=trans), NOT be
#     an alias on Central Office — otherwise every CO employee resolves to the
#     same school_id and gets mis-flagged as transportation. Run
#     bin/split_transportation_building.php once to set this up. PowerSchool has
#     no transportation location (those staff come across as SchoolID 0 / CO), so
#     the code is NextGen-only.
#AD_OU_SRO=OU=SRO

# --- AD group membership (Phase 4 — the `groups` reconciler phase) ------------
# IDM computes each person's group set (GroupPolicy) and diffs it against live
# memberOf, adding what's missing and removing memberships it MANAGES that no
# longer apply (groups outside the managed set are never touched). The matching
# RULES are fixed in code; the group NAMES below are configurable — confirm they
# match the real AD group names before enabling.
#
# Fixed groups (everyone → All-Faculty; bus drivers → Transportation).
#AD_GROUP_ALL_FACULTY=All-Faculty
#AD_GROUP_TRANSPORTATION=Transportation
# Per-school Everyone group = <building OU token><suffix>, e.g. OU=CO → CO-Everyone
# (naming exceptions RQES→RQS and UPE→UP are baked in).
#AD_GROUP_EVERYONE_SUFFIX=-Everyone
# Microsoft 365 license groups (A1 for CNP/custodian/bus driver/aide/sub/intern/
# SRO titles + all contractors; A3 for everyone else).
#AD_GROUP_M365_A1=M365 A1 License
#AD_GROUP_M365_A3=M365 A3 License
# Raptor role groups. Assigned by job title (first match wins): BuildingAdmin
# (Principal, IT Computer Tech); ClientAdmin (IT Technician Supervisor, Safety
# Contractor, Director of Technology); EntryAdmin (Secretary, bookkeeper);
# GlobalAdmin (Network Administrator, Security Specialist); else the default.
# A per-person EXCEPTION can override the title rule (set on the person page,
# stored on person.raptor_group_override). The names below are the exact AD group
# cn — confirm them before enabling group writes.
#AD_GROUP_RAPTOR_BUILDING_ADMIN=Raptor_BuildingAdmin
#AD_GROUP_RAPTOR_CLIENT_ADMIN=Raptor_ClientAdmin
#AD_GROUP_RAPTOR_ENTRY_ADMIN=Raptor_EntryAdmin
#AD_GROUP_RAPTOR_GLOBAL_ADMIN=Raptor_GlobalAdmin
#AD_GROUP_RAPTOR_DEFAULT=Raptor_EmergencyManagementUser
#
# Group-membership endpoint. One path for both operations (Adaxes 2025.x):
#   add    = POST   {base}/api/directoryObjects/groupMembers  {"group":…,"newMember":…}
#   remove = DELETE {base}/api/directoryObjects/groupMembers?group=…&member=…
# The reconciler resolves each group NAME to its DN before calling. Default shown;
# override only if your Adaxes version differs.
#ADAXES_GROUP_MEMBERS_PATH=api/directoryObjects/groupMembers

# --- Email (rename notices, alias-expiry reminders, notifications) ------------
# IDM emails employees/principals/IT for rename cutovers and alias-expiry
# reminders. Every send is logged to email_outbox. OFF by default: with
# MAIL_ENABLED=false messages are composed and queued but not delivered.
MAIL_ENABLED=false
MAIL_FROM=idm@tusc.k12.al.us          # envelope/header From
MAIL_TRANSPORT=null                   # null | sendmail | smtp
# SMTP transport (an internal relay, or Exchange Online submission on :587).
# Confirm host/port/security against your relay before enabling.
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_SECURITY=tls                    # none | tls (STARTTLS) | ssl (implicit)
#SMTP_USER=
#SMTP_PASS=
#SMTP_TIMEOUT=15
#SMTP_EHLO=                           # EHLO hostname; defaults to the APP_URL host
# Where notices go besides the employee: IT always; the school principal is
# looked up from the golden record (title contains "Principal" at their school).
IT_NOTIFY_EMAIL=                      # comma-separated IT recipients for rename/alias notices

# --- Rename / alias lifecycle (username change on last-name change) -----------
# When a person's legal last name changes, IDM mints the new username and
# schedules the cutover for RENAME_NOTICE_DAYS out (notice emailed now). The old
# email keeps delivering as an AD/Google alias for RENAME_ALIAS_DAYS, with
# reminder emails RENAME_ALIAS_REMINDER_DAYS before removal.
#RENAME_NOTICE_DAYS=7
#RENAME_ALIAS_DAYS=90
#RENAME_ALIAS_REMINDER_DAYS=14,3      # days-before-removal to send reminders

# --- Google Workspace direct provisioning (Admin SDK API or GAM) -------------
# Optional. When enabled, the app provisions Google accounts DIRECTLY from the
# golden record, BYPASSING OneSync — the person detail page gains a Google panel
# (correlate + Link / Create / Push / Suspend / Restore) and a batch reconcile
# (bin/sync_google.php + the "Sync to Google" import action). It does OneSync-style
# correlation (crosswalk id → primary email → employee id (externalId) → name)
# before creating, so it never duplicates an existing account. "Disable" is a
# SUSPEND (reversible), never a delete. Creating requires a golden email already
# on file — the app never invents an address.
#
# Master switch. Leave false to keep everything off (panel shows a notice).
GOOGLE_DIRECT_ENABLED=false
# How the app talks to Google — correlation/write logic is identical either way:
#   api (default): built-in Admin SDK client, authenticated with the GOOGLE_SA_*
#     service account below. No extra software on the host.
#   gam: shell out to GAM (https://github.com/GAM-team/GAM), the CLI Workspace
#     admins already run. Auth lives entirely in GAM's own project/config
#     ('gam config' / GAMCFGDIR), so the app holds NO Google key of its own —
#     the GOOGLE_SA_* block below is then not needed. Requires GAM7 on the
#     host, authorized (gam create project / gam oauth create, or an existing
#     GAMCFGDIR) for the user the app/timer runs as.
GOOGLE_BACKEND=api
# GAM backend only: absolute path to the gam binary (required to turn gam on),
# an optional shared GAM config dir (exported as GAMCFGDIR; empty = that user's
# ~/.gam), and a per-command timeout — a gam run is slower than a raw API call.
#GAM_PATH=/usr/local/bin/gam
#GAM_CONFIG_DIR=/var/idm/gam
#GAM_TIMEOUT=60
# API backend: auth is a service account with DOMAIN-WIDE DELEGATION. In the Google Admin
# console, authorize the SA's client ID for the scope below, and impersonate a
# super-admin (or a user with the Admin API user-management privilege).
# Run `php bin/google_auth_check.php` to verify this end-to-end — it checks the
# key, token exchange, and a delegated API call, and prints the exact Admin
# console client ID + scope to authorize when something's missing.
# Point this at the downloaded service-account JSON key (client_email +
# private_key are read from it). Keep the file readable only by the app user.
GOOGLE_SA_KEY_FILE=       # e.g. /var/idm/google-sa.json
# Alternatively, inline the JSON, or set the two fields explicitly (these win):
#GOOGLE_SA_JSON=
#GOOGLE_SA_CLIENT_EMAIL=svc-idm@your-project.iam.gserviceaccount.com
#GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n…"
# The admin user the SA impersonates for Directory API calls (required).
GOOGLE_ADMIN_SUBJECT=     # e.g. idm-admin@tuscaloosacityschools.com
# Your Google Workspace primary domain, and the Directory API customer id.
# Used to correlate a person to their Google account: the golden email/UPN is
# usually in the on-prem domain (e.g. @tusc.k12.al.us), so correlation also
# looks up <username>@GOOGLE_DOMAIN (the person's real Google address).
GOOGLE_DOMAIN=            # e.g. tuscaloosacityschools.com
GOOGLE_CUSTOMER=my_customer
# OAuth scope. Directory user management. Change only if you know why.
#GOOGLE_SCOPES=https://www.googleapis.com/auth/admin.directory.user
# Seconds to wait for Google before giving up (the panel degrades gracefully).
GOOGLE_TIMEOUT=10
# TLS: keep verification ON. For an outbound proxy with a private CA, point
# GOOGLE_CA_FILE at the CA bundle. Only disable for a host you cannot trust.
GOOGLE_VERIFY_TLS=true
GOOGLE_CA_FILE=
# Batch guardrail: if the share of accounts a run would SUSPEND exceeds this
# ratio across a population of at least GOOGLE_SYNC_GUARD_MIN linked accounts,
# the whole run is BLOCKED (nothing written) so a bad feed can't mass-suspend.
GOOGLE_SYNC_MAX_RATIO=0.2
GOOGLE_SYNC_GUARD_MIN=20
# "Run Google sync now" button on the Import & feeds page. Like the AD sync, a
# full run does a live Google lookup per person (minutes, not seconds), so it
# CANNOT run in the web request — doing so ties up a PHP-FPM worker and exhausts
# pm.max_children (nginx 504). The button instead asks systemd to start the
# oneshot unit in the background:
#   sudo -n systemctl start --no-block idm-google-sync.service
# Off by default; the host must also grant the web user the sudoers rule in
# deploy/idm-google-run.sudoers. A dry-run preview is a CLI operation
# (php bin/sync_google.php --dry-run). The Services page shows the last run.
GOOGLE_RUN_ENABLED=false
#GOOGLE_SERVICE_UNIT=idm-google-sync.service
#GOOGLE_SUDO_BIN=sudo
#GOOGLE_SYSTEMCTL_BIN=systemctl
#GOOGLE_RUN_TIMEOUT=15
# OU placement. Active accounts are placed/kept in their building's OU
# (school.google_ou); the sync moves an active user whose OU has drifted back to
# it (via a push). Suspended accounts are moved to the disabled OU below. Set to
# blank to turn the disabled-OU move off entirely.
GOOGLE_DISABLED_OU=/tcs/faculty/disabled
# Licensing (Google Workspace for Education Plus — staff). When on, the sync
# assigns the SKU to active faculty/staff (checking seat availability first) and
# removes it from suspended accounts. Off unless GOOGLE_LICENSE_ENABLED=true AND
# GOOGLE_LICENSE_SKU is set.
#   SKU      — the Education Plus (staff) SKU id, e.g. 1010310008.
#   PRODUCT  — the product id (e.g. 101031). GAM infers it; REQUIRED for the API
#              backend. On the API backend the service account also needs the
#              https://www.googleapis.com/auth/apps.licensing scope (add it to the
#              domain-wide delegation AND to GOOGLE_SCOPES).
#   SEATS    — the subscription's seat cap. 0/blank = uncapped (no availability
#              gate); set it to have the sync refuse to over-assign.
GOOGLE_LICENSE_ENABLED=false
GOOGLE_LICENSE_SKU=
GOOGLE_LICENSE_PRODUCT=
GOOGLE_LICENSE_SEATS=0
# Advanced (tests only): override the API/token hosts.
#GOOGLE_API_BASE=https://admin.googleapis.com/admin/directory/v1
#GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# --- SAML SSO (district IdP) -----------------------------------------------
# CONFIRM IdP (ADFS / Entra ID / Google), metadata, entityID, and certs.
# These are placeholders wired in Milestone 7.
SAML_SP_ENTITY_ID=https://identity.tuscaloosacityschools.com/saml/metadata
SAML_SP_ACS_URL=https://identity.tuscaloosacityschools.com/saml/acs
SAML_SP_SLS_URL=https://identity.tuscaloosacityschools.com/saml/sls
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
# IdP token-SIGNING cert. Either paste the base64 body here as ONE UNBROKEN LINE
# (no -----BEGIN/END----- lines, no spaces — .env is line-based, so a multi-line
# paste is silently truncated and you get "Unable to extract public key"), OR
# leave this blank and point SAML_IDP_X509_CERT_FILE at a PEM file (multi-line OK).
SAML_IDP_X509_CERT=
SAML_IDP_X509_CERT_FILE=/var/idm/saml/idp.crt
# Path to SP private key/cert (kept outside the web root).
SAML_SP_PRIVATE_KEY_FILE=/var/idm/saml/sp.key
SAML_SP_CERT_FILE=/var/idm/saml/sp.crt

# Comma-separated emails granted 'admin' on first SSO login (bootstrap admins).
# You can also grant roles from the CLI: php bin/set_role.php --email=.. --role=admin
ADMIN_EMAILS=

# SAML debug log — set true to record WHY a login failed (destination/HTTPS
# mismatch, signature/cert problems, clock skew, unsigned assertion) to a known
# file, even when php-fpm worker error_log isn't visible in the journal. The log
# contains the decoded SAML response (identity attributes = PII), so enable only
# while debugging and turn it back off. Path is SAML_LOG (default below).
SAML_DEBUG=false
SAML_LOG=/var/idm/saml/saml_debug.log

# Which SAML signature the SP requires. The IdP must sign SOMETHING; keep at
# least one of these true. ClassLink (and many IdPs) sign the response/message,
# which covers the assertion — that's the default. If your IdP signs the
# assertion element itself instead, set MESSAGES=false and ASSERTIONS=true.
SAML_WANT_MESSAGES_SIGNED=true
SAML_WANT_ASSERTIONS_SIGNED=false
