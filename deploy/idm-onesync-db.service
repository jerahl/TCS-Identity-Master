[Unit]
Description=TCS Identity — import OneSync results from OneSync DB
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/idm
ExecStart=/usr/bin/php /var/www/idm/bin/import_onesync_db.php
TimeoutStartSec=1800
Nice=10
