[Unit]
Description=TCS Identity — reconcile the golden record to Active Directory via Adaxes (create/edit/disable/groups)
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/idm
ExecStart=/usr/bin/php /var/www/idm/bin/adaxes_sync.php
# Per-person live AD lookups make a full run slow; allow up to an hour.
TimeoutStartSec=3600
Nice=10
