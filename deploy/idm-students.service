[Unit]
Description=TCS Identity — pull students from PowerSchool (ODBC) into the OneSync source
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/idm
ExecStart=/usr/bin/php /var/www/idm/bin/import_students.php
TimeoutStartSec=1800
Nice=10
